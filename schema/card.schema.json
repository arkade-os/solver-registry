{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://github.com/ArkLabsHQ/solver-registry/schema/card.schema.json",
  "title": "Solver card",
  "description": "One solver's market listing for one network. Path: solvers/<network>/<name>.json",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "version",
    "name",
    "markets"
  ],
  "dependencies": {
    "sig": [
      "discovery_pubkey"
    ]
  },
  "definitions": {
    "asset": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "name",
        "ticker",
        "precision"
      ],
      "properties": {
        "id": {
          "type": "string",
          "pattern": "^(btc|[0-9a-f]{68})$",
          "description": "Canonical asset identity: \"btc\" or a 68-hex-char AssetId."
        },
        "name": {
          "type": "string",
          "minLength": 1,
          "maxLength": 64
        },
        "ticker": {
          "type": "string",
          "minLength": 1,
          "maxLength": 16
        },
        "precision": {
          "type": "integer",
          "minimum": 0,
          "maximum": 18,
          "description": "Number of decimals: base-units per display unit = 10^precision."
        }
      }
    }
  },
  "properties": {
    "version": {
      "const": 0
    },
    "name": {
      "type": "string",
      "pattern": "^[a-z0-9-]+$",
      "description": "Unique within the network directory; must equal the filename (without .json)."
    },
    "discovery_pubkey": {
      "type": "string",
      "pattern": "^[0-9a-f]{64}$",
      "description": "BIP340 x-only public key, lowercase hex."
    },
    "sig": {
      "type": "string",
      "pattern": "^[0-9a-f]{128}$",
      "description": "BIP340 Schnorr signature by discovery_pubkey over sha256(canonical_json)."
    },
    "markets": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "pair",
          "base_asset",
          "quote_asset",
          "price_feed",
          "price_decimals",
          "invert",
          "fee_bps",
          "min_base_amount",
          "max_base_amount"
        ],
        "properties": {
          "pair": {
            "type": "string",
            "pattern": "^[A-Za-z0-9._-]{1,16}/[A-Za-z0-9._-]{1,16}$",
            "description": "Display pair \"<base-ticker>/<quote-ticker>\"; must equal base_asset.ticker + \"/\" + quote_asset.ticker. Canonical identity lives in base_asset.id / quote_asset.id."
          },
          "base_asset": {
            "$ref": "#/definitions/asset",
            "description": "Display metadata for the pair's base side."
          },
          "quote_asset": {
            "$ref": "#/definitions/asset",
            "description": "Display metadata for the pair's quote side."
          },
          "price_feed": {
            "type": "string",
            "format": "uri",
            "pattern": "^https://"
          },
          "price_decimals": {
            "type": "integer",
            "minimum": 0,
            "maximum": 18
          },
          "invert": {
            "type": "boolean"
          },
          "fee_bps": {
            "type": "integer",
            "minimum": 0,
            "maximum": 10000
          },
          "min_base_amount": {
            "type": "integer",
            "minimum": 1
          },
          "max_base_amount": {
            "type": "integer",
            "minimum": 1
          }
        }
      }
    }
  }
}
