{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://github.com/arkade-os/solver-registry/schema/index.schema.json",
  "title": "Per-network market index",
  "description": "Reduced, flattened output for one network: <network>.json",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "version",
    "network",
    "generated_at",
    "commit",
    "markets"
  ],
  "definitions": {
    "asset": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "name",
        "ticker",
        "decimals"
      ],
      "properties": {
        "id": {
          "type": "string",
          "pattern": "^(btc|[0-9a-f]{68})$",
          "description": "Canonical asset identity: \"btc\" or a 68-hex-char AssetId."
        },
        "name": {
          "type": "string",
          "minLength": 1,
          "maxLength": 64
        },
        "ticker": {
          "type": "string",
          "minLength": 1,
          "maxLength": 16
        },
        "decimals": {
          "type": "integer",
          "minimum": 0,
          "maximum": 18
        }
      }
    },
    "priceFeedSchema": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "type",
        "price_path"
      ],
      "properties": {
        "type": {
          "const": "json",
          "description": "The price feed response is JSON."
        },
        "price_path": {
          "type": "string",
          "pattern": "^(?:/(?:[^~/]|~0|~1)*)*$",
          "description": "RFC 6901 JSON Pointer to the numeric feed value, e.g. /price or /bitcoin/usd. Empty string selects the whole JSON document."
        }
      }
    },
    "amount": {
      "type": "string",
      "pattern": "^(0|[1-9][0-9]{0,29})$",
      "description": "A canonical decimal-string amount of atomic units: unsigned, no leading zeros. \"0\" disables the side it bounds."
    },
    "enabledAmount": {
      "type": "string",
      "pattern": "^[1-9][0-9]{0,29}$",
      "description": "An amount that is strictly positive: the side it bounds is enabled."
    }
  },
  "properties": {
    "version": {
      "const": 0
    },
    "network": {
      "type": "string",
      "enum": [
        "bitcoin",
        "signet",
        "mutinynet"
      ]
    },
    "generated_at": {
      "type": "integer",
      "minimum": 0,
      "description": "Unix seconds, set by CI."
    },
    "commit": {
      "type": "string",
      "pattern": "^[0-9a-f]{40}$"
    },
    "markets": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "pair",
          "solver",
          "base_asset",
          "quote_asset",
          "price_feed",
          "price_feed_schema",
          "price_decimals",
          "fee_bps",
          "min_base_amount",
          "max_base_amount",
          "min_quote_amount",
          "max_quote_amount"
        ],
        "anyOf": [
          {
            "properties": {
              "max_base_amount": {
                "$ref": "#/definitions/enabledAmount"
              }
            }
          },
          {
            "properties": {
              "max_quote_amount": {
                "$ref": "#/definitions/enabledAmount"
              }
            }
          }
        ],
        "properties": {
          "pair": {
            "type": "string",
            "pattern": "^[A-Za-z0-9._-]{1,16}/[A-Za-z0-9._-]{1,16}$",
            "description": "Display pair \"<base-ticker>/<quote-ticker>\"; must equal base_asset.ticker + \"/\" + quote_asset.ticker. Canonical identity lives in base_asset.id / quote_asset.id."
          },
          "solver": {
            "type": "string",
            "pattern": "^[a-z0-9-]+$"
          },
          "base_asset": {
            "$ref": "#/definitions/asset"
          },
          "quote_asset": {
            "$ref": "#/definitions/asset"
          },
          "discovery_pubkey": {
            "type": "string",
            "pattern": "^[0-9a-f]{64}$"
          },
          "price_feed": {
            "type": "string",
            "format": "uri",
            "pattern": "^https://"
          },
          "price_feed_schema": {
            "$ref": "#/definitions/priceFeedSchema"
          },
          "price_decimals": {
            "type": "integer",
            "minimum": 0,
            "maximum": 18,
            "description": "The feed value divided by 10^price_decimals is the price in quote-atomic-units per base-atomic-unit."
          },
          "fee_bps": {
            "type": "integer",
            "minimum": 0,
            "maximum": 10000
          },
          "min_base_amount": {
            "$ref": "#/definitions/amount",
            "description": "Lower trade-size bound for the base side, in base atomic units. An enabled side has 1 <= min <= max; when the side is disabled (max = \"0\") min MUST be \"0\"."
          },
          "max_base_amount": {
            "$ref": "#/definitions/amount",
            "description": "Upper trade-size bound for the base side, in base atomic units. \"0\" disables the side: the solver does not pay out base and makers cannot receive it."
          },
          "min_quote_amount": {
            "$ref": "#/definitions/amount",
            "description": "Lower trade-size bound for the quote side, in quote atomic units. An enabled side has 1 <= min <= max; when the side is disabled (max = \"0\") min MUST be \"0\"."
          },
          "max_quote_amount": {
            "$ref": "#/definitions/amount",
            "description": "Upper trade-size bound for the quote side, in quote atomic units. \"0\" disables the side: the solver does not pay out quote and makers cannot receive it."
          }
        }
      }
    }
  }
}
